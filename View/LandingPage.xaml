<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Homeapp.View.LandingPage"
             NavigationPage.HasNavigationBar="False">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Grid">
                <Setter ="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal"/>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                    
                </Setter>
            </Style>
            <ControlTemplate x:Key="SectionTemplate">
                <Border BackgroundColor="#F0F0F1" WidthRequest="120" StrokeShape="RoundedRectangle 20" StrokeThickness="0">
                    <Label x:Name="label" Text="{TemplateBinding Content}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" Padding="8"/>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CheckedStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#4C65FF"/>
                                        <Setter TargetName="label" Property="Label.Opacity" Value="1"/>
                                        <Setter TargetName="label" Property="Label.TextColor" Value="White"/>   
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#F0F0F1"/>
                                        <Setter TargetName="label" Property="Label.Opacity" Value="0.6 "/>
                                        <Setter TargetName="label" Property="Label.TextColor" Value="Black"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                     </VisualStateManager.VisualStateGroups>
                </Border>   
            </ControlTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid RowDefinitions="Auto, Auto, *" HorizontalOptions="Fill" VerticalOptions="Fill" Padding="32" BackgroundColor="#FEFEFE" RowSpacing="32">
        <Grid HorizontalOptions="Fill">
            <VerticalStackLayout Grid.Row="0" Spacing="16" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="HomeApp" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center"/>  
                    <Label Text="Welcome to HomeApp" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>  
            </VerticalStackLayout>
            <Border Grid.Row="1" Padding="16" BackgroundColor="#E0E0E0">
                  <Label Text="Your home, your way" FontSize="18" FontAttributes="Italic" HorizontalOptions="Center"/>
                  <Image Source="homeapp_logo.png" Aspect="AspectFit" HeightRequest="100" WidthRequest="100" HorizontalOptions="Center"/>
            </Border>   
        </Grid>
        <Grid Grid.Row="2" HorizontalOptions="Fill" VerticalOptions="End">
            <Button Text="Get Started" FontSize="18" BackgroundColor="#007ACC" TextColor="White" CornerRadius="8" HeightRequest="50" Clicked="OnGetStartedClicked"/>    
        </Grid>
        <Grid Grid.Row="1" RowDefinitions="Auto, Auto, Auto" HorizontalOptions="Fill">
            <Label Text="Features" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Image Source="features_image.png" Aspect="AspectFit" HeightRequest="150" WidthRequest="150" HorizontalOptions="Center"/>
            <Line Grid.Row="1" X1="0" X2="1000" Stroke="#F0F0F1"/>
            <ScrollView Orientation="Horizontal" Grid.Row="2" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout x:Name="SectionList" Margin="0, 20, 0, 0" BindableLayout.ItemsSource="{Binding Sections}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding .}" ControlTemplate="{StaticResource SectionTemplate}" />  
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </Grid>
        <CollectionView x:Name="colView" Grid.Row="2" ItemsSource="{Binding Properties}" VerticalScrollBarVisibility="Never" SelectionMode="Single" SelectedItem="{Binding SelectedProperty}" SelectionChangedCommand="{Binding Propertyelected}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid HeightRequest="210" WidthRequest="160">
                        <VerticalStackLayout Spacing="10">
                            <Border HeightRequest="160" StrokeThickness="0">
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" VerticalOptions="Fill"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding Adress}" TextColor="Black" FontSize="12" Opacity=".5"/>
                            <Label Text="{Binding Price, StringFormat='${0:###,###}'}" TextColor="Black" FontSize="16" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    <Grid>
            
</ContentPage>