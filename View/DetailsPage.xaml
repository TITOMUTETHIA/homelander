<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Homeapp.View.DetailsPage"
             NavigationPage.HasNavigationBar="False">
    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
        <Image Aspect="AspectFill" Source="{Binding SelectedProperty.DefaultImage}"/>   
        <Grid RowDefinitions="*,Auto">
            <VerticalStackLayout x:Name="SideView">   
                <Grid x:Name="imagesView" WidthRequest="80" VerticalOptions="Start" HorizontalOptions="End" Margin="0,80,20,0">
                    <Rectangle Fill="White" RadiusX="40" RadiusY="40" StrokeThickness="0" Opacity=".9"/>
                    <CollectionView Margin="0,10" ItemSizingStrategy="{Binding HomeImages}"
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border WidthRequest="60" HeightRequest="60" HorizontalOptions="Center" StrokeShape="RoundedRectangle 30" StrokeThickness="0" Margin="0,0,0,10">
                                                <Image Aspect="AspectFill" Source="{Binding .}" WidthRequest="60" HeightRequest="60" HorizontalOptions="Center"/>    
                                            </Border>
                                        </DataTemplate>
                                            
                                    </CollectionView.ItemTemplate>
                                    <CollectionView.Footer>
                                        <Border WidthRequest="60" HeightRequest="60" HorizontalOptions="Center" BackgroundColor="Blue" StrokeShape="RoundedRectangle 30" StrokeThickness="0" Margin="0,0,0,10">
                                            <Label Text="{Binding MoreItems, StringFormat='+ {0}'}" FontSize="30" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>   

                                    </CollectionView.Footer>


                    </CollectionView>
                    
                </Grid>
                <Grid x:Name="detailsBtn" HorizontalOptions="End" Margin="0,60,20,0">
                    <Rectangle Fill="White" RadiusX="60" RadiusY="60" StrokeThickness="0" Opacity=".9" HeightRequest="115" WidthRequest="115"/>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="arrow.png" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Label Text="Details" FontSize="20" TextColor="black" Opacity=".5"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
            <Grid x:Name="PopView" Grid.Row="1">
                <Border BackgroundColor="White" StrokeShape="RoundedRectangle 35,35,0,0" StrokeThickness="0" Opacity=".9" HorizontalOptions="Fill"/>
                <Grid Padding="30">
                    <VerticalStackLayout>
                        <VerticalStackLayout x:Name="AddressView">
                            <Label Text="{Binding SelectedProperty.Address}" FontSize="20" Opacity=".5" TextColor="Black"/>
                            <Label Text="{Binding SelectedProperty.Price, StringFormat='Price: {0:###,###}'}" FontSize="Body" FontAttributes="Bold" TextColor="Black"/>
                        </VerticalStackLayout>
                        <Button x:Name="buyButton" Text="Buy Now" BackgroundColor="#4C65FF" TextColor="White" FontSize="18" CornerRadius="25" HeightRequest="50" Clicked="OnContactAgentClicked" HorizontalOptions="Start" Margin="0,20,0,0"/>
                    
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
